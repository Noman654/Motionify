{
  "name": "reel-composer",
  "private": true,
  "version": "1.2.5",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on tcp:3000 && ELECTRON_START_URL=http://localhost:3000 electron .\"",
    "electron:pack": "vite build && electron-builder build --mac"
  },
  "build": {
    "appId": "com.reelcomposer.app",
    "productName": "Reel Composer",
    "mac": {
      "category": "public.app-category.video"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    }
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.11.0",
    "@google/genai": "^1.34.0",
    "@tailwindcss/vite": "^4.1.18",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.562.0",
    "prismjs": "^1.30.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-simple-code-editor": "^0.14.1",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.3"
  }
}
